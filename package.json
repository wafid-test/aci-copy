{
  "name": "aci-api",
  "private": true,
  "scripts": {
    "build": "npm --prefix access-backend run build",
    "start": "npm --prefix access-backend run start",
    "backend:install": "npm --prefix backend install",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend start",
    "access-backend:install": "npm --prefix access-backend install",
    "access-backend:dev": "npm --prefix access-backend run dev",
    "access-backend:build": "npm --prefix access-backend run build",
    "access-backend:start": "npm --prefix access-backend run start",
    "frontend:install": "npm --prefix frontend install",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend start",
    "install:all": "npm run backend:install && npm run frontend:install"
  }
}
